// ─────────────────────────────────────────────────────────────────────────────
// LifePlanOS — data model
//
// This schema is the foundation of the multi-tenant SaaS: the Firm Subscription
// System (Module 1) plus a tenant-scoped Case root that the rest of the product
// (intake → records → chronology → future care → pricing → report) hangs off of.
//
// Every table lives in an isolated `lifeplanos` Postgres schema (configured via
// the `schema=lifeplanos` query param on DATABASE_URL), so LifePlanOS is a fully
// standalone application even when it shares a Postgres server with other apps.
//
// PHI/HIPAA note: models holding PHI (Case, and downstream record/chronology
// tables added in later modules) are always accessed through the tenant guard in
// src/lib/tenant.ts, which scopes every query by firmId and writes an AuditLog.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  // Isolated output so this client never collides with any other app's client.
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Subscription / plan ──────────────────────────────────────────────────────

enum PlanTier {
  SOLO
  SMALL_FIRM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// ── Identity / roles ─────────────────────────────────────────────────────────

// Roles map directly to the product spec. Permissions per role are defined in
// code (src/lib/rbac.ts) rather than the DB so the matrix can evolve safely.
enum UserRole {
  ADMIN // firm owner/administrator — full control incl. billing + seats
  PLANNER // life care planner / rehab / nurse consultant — core authoring
  PHYSICIAN_REVIEWER // physician sign-off on medical necessity
  ATTORNEY_REVIEWER // retaining/defense attorney read + comment
  PARALEGAL // intake + record wrangling
  BILLING_USER // billing/subscription only
}

enum UserStatus {
  INVITED // seat created, invitation not yet accepted
  ACTIVE
  SUSPENDED // access revoked but record retained for audit
}

// ── Case ─────────────────────────────────────────────────────────────────────

enum CaseType {
  PERSONAL_INJURY
  MED_MAL
  WORKERS_COMP
  PRODUCT_LIABILITY
  CATASTROPHIC
}

enum CaseSide {
  PLAINTIFF
  DEFENSE
  NEUTRAL
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

// Stages double as the case progress tracker in the UI.
enum CaseStatus {
  INTAKE
  RECORDS
  CHRONOLOGY
  CAUSATION
  FUTURE_CARE
  PRICING
  DRAFTING
  PHYSICIAN_REVIEW
  FINAL
  CLOSED
  ARCHIVED
}

// ── Usage / audit ────────────────────────────────────────────────────────────

enum UsageMetric {
  CASE_CREATED
  RECORD_PAGE_OCR
  AI_GENERATION
  REPORT_EXPORT
  SEAT_ACTIVE
}

// ─────────────────────────────────────────────────────────────────────────────

model Firm {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Firm-branded templates / report letterhead.
  logoUrl      String?
  primaryColor String? @default("#0891b2")
  letterhead   String? // free-text letterhead block for generated reports

  subscription       Subscription?
  users              User[]
  cases              Case[]
  auditLogs          AuditLog[]
  usageRecords       UsageRecord[]
  documents          Document[]
  reports            ReportExport[]
  precedents         PrecedentPlan[]
  validationFindings ValidationFinding[]
  attentionItems     AttentionItem[]
  reasoningAssessments ClinicalReasoningAssessment[]

  @@index([slug])
}

// A finalized life care plan in the firm's precedent library — uploaded or
// synced from an accessible server. Indexed on the attributes that drive the
// "likeness" match so an active case can surface comparable prior LCPs.
model PrecedentPlan {
  id     String @id @default(uuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  title               String // de-identified label, e.g. "L1 burst fracture — CA (2023)"
  clientRef           String? // optional de-identified matter/reference id
  diagnosis           String?
  icd10Code           String?
  injurySpecialty     String? // engine injury category label
  jurisdiction        String?
  mechanism           String?
  age                 Int?
  sex                 String?
  lifeExpectancyYears Float?
  lifetimeCost        Float?
  presentValue        Float?
  careCategories      Json? // string[] of CareCategory present (for overlap scoring)
  outcome             String? // free-text note: settlement/verdict/status

  source        String  @default("upload") // "upload" | "server"
  filename      String?
  storageKey    String?
  extractedText String?

  createdById String?
  createdAt   DateTime @default(now())

  @@index([firmId, createdAt])
  @@index([firmId, injurySpecialty])
}

model Subscription {
  id     String @id @default(uuid())
  firmId String @unique
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  tier   PlanTier           @default(SOLO)
  status SubscriptionStatus @default(TRIALING)

  // Purchased seats. Null = use the plan default from src/lib/subscription/plans.ts.
  seats             Int?
  // Enterprise overrides for negotiated limits. Null = use plan default.
  caseLimitOverride Int?
  seatLimitOverride Int?

  // Stripe linkage (empty in mock billing mode).
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  canceledAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id     String @id @default(uuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  email        String     @unique
  name         String
  role         UserRole   @default(PLANNER)
  status       UserStatus @default(ACTIVE)
  passwordHash String? // null while INVITED (set on invite acceptance)

  // Two-factor authentication (TOTP). Secret is stored server-side; codes are
  // never persisted. Backup codes are stored as one-way hashes.
  mfaEnabled     Boolean @default(false)
  totpSecret     String? // base32 TOTP secret (set once enabled)
  mfaBackupCodes Json? // string[] of sha-256 hashes of unused recovery codes

  // Invitation flow.
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  invitedById     String?

  // Cached "board certified in …" summary rendered in report Qualifications.
  credentialSummary String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions       Session[]
  casesCreated   Case[]           @relation("CaseCreatedBy")
  casesPreparing Case[]           @relation("CasePreparingPhysician")
  auditLogs      AuditLog[]
  usageRecords   UsageRecord[]
  credentials    UserCredential[]

  @@index([firmId])
  @@index([inviteToken])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique // sha-256 of the raw cookie token (raw token never stored)
  expiresAt  DateTime
  lastSeenAt DateTime @default(now()) // drives idle-timeout expiry
  createdAt  DateTime @default(now())
  userAgent  String?
  ip         String?

  @@index([userId])
  @@index([tokenHash])
}

// Throttling record for authentication attempts — powers login rate limiting
// (serverless-safe, unlike in-memory counters). Rows are short-lived.
model LoginAttempt {
  id        String   @id @default(uuid())
  ip        String?
  email     String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model Case {
  id          String @id @default(uuid())
  firmId      String
  firm        Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation("CaseCreatedBy", fields: [createdById], references: [id])

  // EPIC-011 — the physician deemed to be preparing/authoring the report. When
  // set, the report's authorship, Qualifications, and signature (and ONLY that
  // physician's credentials) are drawn from this seat. Null = planner-prepared.
  preparingPhysicianId String?
  preparingPhysician   User?   @relation("CasePreparingPhysician", fields: [preparingPhysicianId], references: [id])

  // Human-friendly per-firm case number (e.g. "LCP-2026-0007").
  caseNumber String

  // Intake (Module 2).
  clientName          String
  dateOfBirth         DateTime?
  sex                 Sex       @default(UNKNOWN)
  caseType            CaseType  @default(PERSONAL_INJURY)
  side                CaseSide  @default(PLAINTIFF)
  jurisdiction        String?
  dateOfInjury        DateTime?
  mechanism           String?
  diagnosis           String? // primary/current diagnosis description
  icd10Code           String? // ICD-10-CM code linked to the primary diagnosis
  additionalDiagnoses Json? // [{ diagnosis, icd10Code }] secondary diagnoses

  // Life-expectancy & economic assumptions (editable, drive the cost engine).
  lifeExpectancyYears Float? // remaining years used for lifetime projections
  discountRate        Float  @default(0.03) // present-value discount rate
  medicalInflation    Float  @default(0.032) // annual medical inflation
  geographicFactor    Float  @default(1.0) // regional cost multiplier

  // Extended intake.
  preExistingConditions String? // comma-separated selected conditions
  preExistingReviewed   Boolean         @default(false) // true once saved in the picker (drives Complete/Incomplete)
  currentWorkStatus     String? // Employed | Unemployed | Disabled
  disabilityReason      String? // shown/used only when currentWorkStatus = Disabled
  functionalLimitations String?
  injurySpecialty       InjurySpecialty @default(GENERAL) // engine injury category (inferred from diagnosis)
  specialty             String? // primary specialty for review (user-selected, descriptive)
  additionalSpecialties Json? // string[] of additional specialties for review

  status    CaseStatus @default(INTAKE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  auditLogs                 AuditLog[]
  documents                 Document[]
  chronologyEvents          ChronologyEvent[]
  conditions                Condition[]
  futureCareItems           FutureCareItem[]
  reviewFindings            ReviewFinding[]
  reports                   ReportExport[]
  socUserInputs             SocUserInput[]
  validationFindings        ValidationFinding[]
  attentionItems            AttentionItem[]
  reasoningAssessments      ClinicalReasoningAssessment[]
  recommendationTransitions RecommendationTransition[]
  evidenceLinks             EvidenceLink[]
  assumptionChanges         AssumptionChange[]
  snapshots                 CaseSnapshot[]
  treatingProviders         TreatingProvider[]
  interviewFindings         InterviewFinding[]

  @@unique([firmId, caseNumber])
  @@index([firmId])
  @@index([firmId, status])
}

// User-supplied input for the Standard-of-Care analysis: free-text notes and
// added source articles/guidelines. Keyed by condition NAME (not id) so it
// survives pipeline regeneration, which recreates conditions. Incorporated into
// the analysis: notes join the evidence corpus; sources become cited guidance.
model SocUserInput {
  id            String @id @default(uuid())
  caseId        String
  case          Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  conditionName String

  kind     String // "note" | "source"
  text     String // note body, or the pertinent quote extracted from the source
  title    String? // source title
  url      String? // source URL / DOI, when provided
  filename String? // uploaded file name, when a file was the source

  addedById String?
  createdAt DateTime @default(now())

  @@index([caseId, conditionName])
}

// Append-only usage meter. Aggregated per billing period for plan-limit checks
// and firm dashboards. `period` is a "YYYY-MM" bucket for cheap monthly rollups.
model UsageRecord {
  id        String      @id @default(uuid())
  firmId    String
  firm      Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  metric    UsageMetric
  quantity  Int         @default(1)
  period    String // "YYYY-MM"
  caseId    String?
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([firmId, period])
  @@index([firmId, metric, period])
}

// Append-only audit trail — every security-relevant and PHI-touching action.
model AuditLog {
  id         String   @id @default(uuid())
  firmId     String
  firm       Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String // e.g. "case.create", "auth.login", "seat.invite", "export.report"
  targetType String? // "case" | "user" | "subscription" | ...
  targetId   String?
  caseId     String?
  case       Case?    @relation(fields: [caseId], references: [id])
  ip         String?
  userAgent  String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([firmId, createdAt])
  @@index([firmId, action])
}

// ─────────────────────────────────────────────────────────────────────────────
// Clinical modules (2–13): records → chronology → causation → future care →
// costs → reviews → report. All tenant-scoped through the owning Case.
// ─────────────────────────────────────────────────────────────────────────────

enum InjurySpecialty {
  GENERAL
  ORTHOPEDIC_TRAUMA
  HIP_ARTHROPLASTY
  KNEE_ARTHROPLASTY
  SPINE
  AMPUTATION
  TBI
  SPINAL_CORD_INJURY
  CHRONIC_PAIN
  CRPS
  BURNS
  BIRTH_INJURY
  NEUROLOGIC
  PSYCHIATRIC
  POLYTRAUMA
}

// Rich medical-legal document taxonomy. Uploaded files are auto-labeled by the
// filename heuristic in src/lib/documents/taxonomy.ts; human-readable labels and
// group membership (for the filtered view) live there too.
enum DocumentType {
  // Emergency & Acute Care
  POLICE_REPORT
  EMS_REPORT
  ER_RECORD
  HOSPITAL_RECORD
  NURSING_NOTE
  DISCHARGE_SUMMARY

  // Surgical & Procedural
  OPERATIVE_NOTE
  ANESTHESIA_RECORD
  PATHOLOGY_REPORT
  IMPLANT_RECORDS

  // Outpatient / Clinic
  MEDICAL_RECORD
  ORTHOPEDIC_CLINIC
  PRIMARY_CARE
  NEUROLOGY_RECORD
  NEUROSURGERY_RECORD
  PAIN_MANAGEMENT
  PHYSICAL_MEDICINE
  PSYCHIATRY_RECORD
  PSYCHOLOGY_RECORD
  CARDIOLOGY_RECORD
  PULMONOLOGY_RECORD
  INFECTIOUS_DISEASE
  INTERNAL_MEDICINE
  ONCOLOGY_RECORD
  WOUND_CARE

  // Rehabilitation & Therapy
  PT_OT_RECORD
  SPEECH_THERAPY
  CHIROPRACTIC_RECORD
  ACUPUNCTURE_RECORD

  // Diagnostics
  IMAGING_REPORT
  LAB_REPORT
  EMG_NCS_REPORT
  NEUROPSYCHOLOGICAL_EVALUATION

  // Life Care Plan & Vocational
  LIFE_CARE_PLAN
  VOCATIONAL_ASSESSMENT
  FUNCTIONAL_CAPACITY_EVALUATION
  REHABILITATION_PLAN
  COST_PROJECTION

  // Financial & Economic
  BILLING_RECORD
  PHARMACY_RECORD
  WAGE_LOSS_DOCUMENTATION
  TAX_RECORDS
  EMPLOYMENT_RECORDS
  INSURANCE_RECORDS

  // Medicolegal / Expert
  IME_REPORT
  EXPERT_REPORT
  PEER_REVIEW
  PRIOR_RECORDS

  // Legal & Liability
  DEPOSITION
  LEGAL_PLEADING
  DEMAND_LETTER
  SETTLEMENT_AGREEMENT
  COURT_ORDER
  CORRESPONDENCE

  // Scene & Evidence
  ACCIDENT_RECONSTRUCTION
  PHOTOGRAPHS
  SURVEILLANCE_VIDEO
  INCIDENT_REPORT

  OTHER
}

enum DocumentStatus {
  UPLOADED
  OCR_PENDING
  PROCESSING
  PROCESSED
  FAILED
}

// Causation classification per the spec.
enum Relatedness {
  RELATED // related to the incident
  AGGRAVATION // aggravation of a pre-existing condition
  PREEXISTING_UNRELATED
  SUBSEQUENT_UNRELATED
  UNCLEAR // requires expert review
}

enum Probability {
  PROBABLE // more likely than not — medical probability
  POSSIBLE
  SPECULATIVE
  NOT_SUPPORTED
}

enum Vulnerability {
  LOW
  MODERATE
  HIGH
}

enum PhysicianStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFIED
}

enum CareCategory {
  PHYSICIAN_VISIT
  SPECIALIST_VISIT
  PRIMARY_CARE
  ORTHOPEDIC_SURGERY
  NEUROSURGERY
  NEUROLOGY
  PMR
  PAIN_MANAGEMENT
  PSYCH
  PHYSICAL_THERAPY
  OCCUPATIONAL_THERAPY
  SPEECH_THERAPY
  COGNITIVE_THERAPY
  MEDICATION
  INJECTION
  IMAGING
  LABS
  DME
  ORTHOTICS_PROSTHETICS
  MOBILITY_AID
  HOME_MODIFICATION
  VEHICLE_MODIFICATION
  ATTENDANT_CARE
  SKILLED_NURSING
  CASE_MANAGEMENT
  VOCATIONAL_REHAB
  FUTURE_SURGERY
  REVISION_SURGERY
  COMPLICATION_MANAGEMENT
  ASSISTIVE_TECH
  SUPPLIES
  TRANSPORTATION
  MISC
}

enum ReviewKind {
  DEFENSE // defense vulnerability critique
  COMPLETENESS // plaintiff completeness check
}

enum ExportFormat {
  DOCX
  PDF
  XLSX
  CSV
  MEMO
}

model Document {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  filename          String
  type              DocumentType   @default(OTHER)
  status            DocumentStatus @default(UPLOADED)
  pageCount         Int            @default(0)
  ocrConfidence     Float? // 0–1; low values flag poor OCR
  storageKey        String? // object-storage pointer (local path in dev)
  extractedText     String? // OCR/parsed text used for extraction + classification
  provider          String? // provider/facility identified from the doc
  serviceDate       DateTime? // documented date (earliest, or the single date)
  serviceDateEnd    DateTime? // latest date when the record spans a range (else null)
  datePages         Json? // number[] — pages on which dated entries appear (range display)
  authorName        String? // primary documenting individual's name
  authorCredentials String? // e.g. "MD", "PT, DPT", "PharmD"
  authorRole        String? // role designation, e.g. "Orthopedic Surgeon"
  facility          String? // primary location/facility
  providers         Json? // [{ name, credentials, role, pages:number[] }] when >1 individual
  locations         Json? // [{ name, pages:number[] }] when >1 location
  // Sub-documents parsed from a consolidated chart at ingest: one entry per
  // dated encounter/section, typed and classified clinical vs. administrative,
  // with page range and a summary. Null for single-encounter records (rendered
  // as a narrative) and legacy rows not yet segmented. See documents/segment.ts.
  segments          Json? // DocumentSegment[]
  flags             String? // e.g. "missing pages", "low OCR confidence"
  // How `type` was assigned: "content" (read from the document body),
  // "filename" (fallback when no text could be extracted), "manual" (user
  // reassigned), or "default". Null for legacy rows.
  classifiedBy      String?
  classifyScore     Float? // strength of the winning content signal
  uploadedById      String?

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([firmId])
}

model ChronologyEvent {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  eventDate            DateTime
  eventDateEnd         DateTime? // encounter range end, when the record spans dates
  eventType            String? // SURGERY|IMAGING|LAB|CLINIC_VISIT|ER_VISIT|HOSPITALIZATION|THERAPY|COMPLICATION|LEGAL_EVENT|BILLING|OTHER
  provider             String?
  specialty            String?
  facility             String? // location/facility for the encounter (LCP header)
  recordType           String?
  summary              String
  // LCP-style encounter fields (Subjective / PMH / Exam / Diagnostic Studies /
  // Assessment / Plan / Procedure / Meds / Disposition / Functional / Work).
  subjective           String?
  pastMedicalHistory   String? // PMH / comorbidities documented at the encounter
  objectiveFindings    String? // Exam
  diagnosis            String? // Assessment
  treatment            String? // Plan
  procedure            String?
  disposition          String?
  imagingFindings      String? // Diagnostic Studies (imaging + labs)
  medications          String?
  restrictions         String?
  workStatus           String?
  functionalStatus     String?
  impairmentRating     String? // MMI status / impairment rating (IME, medicolegal)
  // Why this event matters: which diagnosis it documents and which future-care
  // items it grounds. Ties the timeline to the causation map & the care plan.
  clinicalSignificance String?

  // Source citation back to the originating record.
  sourceDocumentId String?
  sourcePage       Int?
  sourceQuote      String? // verbatim excerpt from the record supporting the event
  dateInferred     Boolean @default(false) // true when no date appeared in the record

  relevanceScore Int         @default(50) // 0–100
  relatedness    Relatedness @default(UNCLEAR)

  edited    Boolean  @default(false) // true once a human edits the AI output
  createdAt DateTime @default(now())

  @@index([caseId, eventDate])
}

// Causation / apportionment per diagnosis (Module 5).
model Condition {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  name        String
  relatedness Relatedness @default(UNCLEAR)
  confidence  Int         @default(50) // 0–100

  supportingRecords String?
  opposingRecords   String?
  objectiveEvidence String?
  // Where the objective evidence actually lives: array of
  // { documentId, filename, page, quote } pointing into the source records.
  evidenceSources   Json?
  missingInfo       String?
  reasoning         String?
  // Standard-of-care analysis for this causation item: located clinical
  // practice guidelines with VERBATIM quoted language (never fabricated — the
  // quote is lifted from the retrieved source), the documented care that
  // corresponds to the guidance, and a documentation status. See SocAnalysis.
  socAnalysis       Json?

  physicianConfirmed Boolean @default(false)

  createdAt DateTime @default(now())

  futureCareItems FutureCareItem[]

  @@index([caseId])
}

// Future care recommendation + inline cost projection (Modules 6, 8) and the
// physician + review status (Modules 10–12).
model FutureCareItem {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  conditionId String?
  condition   Condition? @relation(fields: [conditionId], references: [id])

  category  CareCategory
  service   String // specific service/item
  rationale String? // medical necessity rationale
  specialty String?
  cptCode   String?

  probability Probability @default(POSSIBLE)
  confidence  Int         @default(50)

  // Frequency / duration.
  frequencyPerYear Float   @default(1)
  startTrigger     String? // start date or trigger
  durationYears    Float? // null = lifetime
  isLifetime       Boolean @default(false)

  // Cost projection (unit → lifetime → present value), low/expected/high.
  unitCost      Float   @default(0)
  annualCost    Float   @default(0)
  lifetimeCost  Float   @default(0) // undiscounted
  presentValue  Float   @default(0)
  lowCost       Float   @default(0)
  highCost      Float   @default(0)
  pricingSource String? // Medicare / UCR / cash-pay benchmark note

  // Evidence (Module 9) — never fabricated; states when support is limited.
  evidenceStrength  String? // e.g. "Guideline-supported", "Limited — physician confirmation required"
  literatureSupport String?
  // The two most relevant real supporting articles, ranked across multiple
  // literature sources (Europe PMC, Crossref, Semantic Scholar). Never invented.
  // Array of { source, title, authors, journal, year, url, pmid?, doi? }.
  // Null if none found/offline.
  citation          Json?

  // Alternatives & adversarial framing.
  lowerCostAlternative String?
  plaintiffValue       String?
  defenseVulnerability Vulnerability @default(LOW)
  missingSupport       String?

  // Staged / conditional recommendation metadata (§10). `startTrigger` above is
  // the trigger; these complete the staged picture so a contingent item is never
  // silently totaled alongside the pathway it would replace.
  prerequisite    String? // what must occur first (e.g. "failure of conservative care")
  earliestTiming  String? // earliest expected timing (e.g. "~15 years — implant survivorship")
  replacesService String? // the recommendation that becomes inactive if this triggers (denormalized service name)
  contingencyOnly Boolean @default(false) // disclosed as a contingency; never entered into totals

  // Physician review (Module 12).
  physicianStatus  PhysicianStatus @default(PENDING)
  physicianNote    String?
  physicianSummary String? // paraphrased summary of the medical-necessity point (auto-updated on modify)

  // Recommendation versioning (P2.R1). lineageId is constant across versions;
  // a superseded version keeps its review history and points forward to its
  // replacement. Only rows with supersededAt = null are current/totals-eligible.
  lineageId       String    @default(dbgenerated("(gen_random_uuid())::text"))
  version         Int       @default(1)
  supersededById  String?
  supersededAt    DateTime?
  lifecycleStatus RecStatus @default(AI_DRAFT)

  edited    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([caseId, supersededAt])
  @@index([lineageId])
}

// Recommendation lifecycle states (P2.R1 / spec §12). The legacy 4-state
// physicianStatus is retained and kept in sync; lifecycleStatus is the richer
// presentation/workflow state.
enum RecStatus {
  AI_DRAFT
  PLANNER_PROPOSED
  PLANNER_APPROVED
  RECORD_SUPPORTED
  SENT_FOR_PHYSICIAN_REVIEW
  PHYSICIAN_CLARIFICATION
  PHYSICIAN_APPROVED
  PHYSICIAN_MODIFIED
  PHYSICIAN_REJECTED
  ATTORNEY_REVIEWED
  LOCKED_FOR_EXPORT
  SUPERSEDED
}

// Ledger of every recommendation status transition (P2.R1 §4): who, in what
// role, when, from what to what, with the changed fields and materiality.
// Linked by lineageId (stable) + itemId (the specific version acted on).
model RecommendationTransition {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  lineageId      String
  itemId         String
  userId         String?
  role           String? // actor role, or "system" for pipeline actions
  priorStatus    String
  newStatus      String
  comment        String?
  modifiedFields Json? // string[] of changed field names
  materialChange Boolean @default(false)
  caseVersion    Int? // populated from CaseSnapshot once available

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([lineageId])
}

// Evidence graph (P2): materialized relationships between clinical artifacts.
// Derived data — rebuilt at generation; never user-authored.
model EvidenceLink {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  kind     String // DIAGNOSIS_EVIDENCE | REC_DIAGNOSIS | REC_LITERATURE | REC_GUIDELINE | CONTRADICTS
  fromType String // "condition" | "futureCareItem"
  fromId   String
  toType   String // "document" | "condition" | "citation" | "guideline"
  toId     String? // null for external targets carried in meta (citations)

  documentId String?
  page       Int?
  quote      String?
  meta       Json? // e.g. { title, pmid, doi, url } for literature targets

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([caseId, fromType, fromId])
}

// Ledger of case economic-assumption changes (P3): original vs revised, who,
// when, why — so a report's numbers are always explainable across versions.
model AssumptionChange {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  field         String // lifeExpectancyYears | discountRate | medicalInflation | geographicFactor
  originalValue Float?
  revisedValue  Float?
  reason        String?
  userId        String?

  createdAt DateTime @default(now())

  @@index([caseId])
}

// Point-in-time digest of a case's clinical/economic state (P3), captured on
// each report export so any two versions can be compared. Payload is a compact
// JSON digest (ids + display fields), not a full data dump.
model CaseSnapshot {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  version        Int // matches ReportExport.version when export-triggered
  reportExportId String?
  payload        Json
  createdById    String?

  createdAt DateTime @default(now())

  @@unique([caseId, version])
  @@index([caseId])
}

// Findings from the defense-vulnerability and plaintiff-completeness reviews.
model ReviewFinding {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  kind          ReviewKind
  category      String // topic of the contested point
  description   String // the argument being made
  vulnerability Vulnerability @default(MODERATE) // severity for DEFENSE; priority for COMPLETENESS
  relatedItemId String? // FutureCareItem it refers to, when applicable

  // Contested-point structure: which side raises the argument, its source, and
  // the opposing side's counter-argument with its own supporting source.
  side            String? // "DEFENSE" | "PLAINTIFF" — who raises the primary argument
  sourceRef       String? // source backing the argument (record / plan basis)
  counterArgument String?
  counterSource   String? // narrative source / literature backing the counter-argument
  counterCitation String? // formal citation (authority/guideline/text) for the support

  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([caseId, kind])
}

// Export/version history (Modules 13–14).
model ReportExport {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  format            ExportFormat
  template          CaseSide     @default(PLAINTIFF) // plaintiff/defense/neutral template
  draft             Boolean      @default(false) // CRE v1 — draft export (watermark + unresolved-issues appendix)
  version           Int          @default(1)
  storageKey        String?
  generatedById     String?
  totalLifetimeCost Float        @default(0)
  totalPresentValue Float        @default(0)
  itemCount         Int          @default(0)

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([firmId])
}

// A persisted result of the deterministic Life Care Plan integrity check
// (src/lib/engine/integrity.ts). Findings are recomputed and REPLACED whenever
// the plan is (re)generated or a report is exported — they are derived data,
// never user-authored. Item linkage is by denormalized service name (not FK)
// because future-care items are recreated on regeneration.
model ValidationFinding {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)

  service        String // recommendation (service) the finding concerns
  result         String // e.g. "Code mismatch", "Diagnosis mismatch"
  issue          String // human-readable description of the problem
  severity       String // Critical | High | Moderate | Low
  suggestion     String // suggested correction
  exportBlocking Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([firmId])
}

// Case Review Assistant — an attention item is a persisted, lifecycle-tracked
// PROJECTION of a deterministic finding (ValidationFinding / integrity /
// consistency / evidence / physician-review status). The assistant does not
// invent issues; it explains and prioritizes structured findings and tracks
// their triage (assign / resolve / defer / dismiss) with audit history that the
// atomically-replaced ValidationFinding rows cannot hold.
enum AttentionSeverity {
  CRITICAL
  HIGH
  MODERATE
  LOW
  INFORMATIONAL
}

enum AttentionStatus {
  OPEN
  IN_REVIEW
  DEFERRED
  RESOLVED
  DISMISSED
  SUPERSEDED
}

// Clinical Reasoning Engine (Phase A). A structured, versioned assessment of
// whether ONE future-care recommendation is medically supportable for THIS
// patient — computed by the reasoning pipeline (reusing the dossier, integrity,
// consistency, and citation engines) and PERSISTED so the report narrative and
// Evidence Explorer render FROM it ("reason first, write second"). References
// existing Condition / citation / review records rather than duplicating them.
enum ReasoningStatus {
  NEEDS_REASONING_REVIEW // legacy default for backfilled / not-yet-assessed rows
  ASSESSED // legacy "computed" status (pre-v1); new writes use the states below
  SUPERSEDED
  // CRE v1 lifecycle:
  PENDING // queued, not yet computed
  PROCESSING // computation in flight
  NEEDS_REVIEW // computed, but a gate (frequency, lifetime, unknowns, approval invalidation) needs human review
  VALIDATED // computed and every gate passed
  INVALID // computed and a structural defect found (diagnosis/laterality/coding mismatch)
  ERROR // computation failed; see errorDetail
}

enum ProbabilityClassification {
  PROBABLE_INCLUDED
  CONDITIONAL_STAGED
  POSSIBLE_CONTINGENCY_NOT_INCLUDED
  INSUFFICIENTLY_SUPPORTED
  NOT_RECOMMENDED
  REJECTED_BY_REVIEWER
}

enum EvidenceStrength {
  STRONG
  MODERATE
  LIMITED
  EXPERT_CONSENSUS
  INSUFFICIENT
}

enum RecommendationConfidence {
  HIGH
  MODERATE
  LOW
  INDETERMINATE
}

model ClinicalReasoningAssessment {
  id     String @id @default(uuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  recommendationId      String // FutureCareItem.id — version-specific (each row IS a version)
  recommendationService String // denormalized service name (stable across regen)
  status                ReasoningStatus @default(NEEDS_REASONING_REVIEW)

  // CRE v1 — lineage / version awareness. The recommendationId already pins a
  // specific FutureCareItem version; these make the chain queryable.
  recommendationLineageId String? // FutureCareItem.lineageId (constant across versions)
  recommendationVersion   Int? // FutureCareItem.version
  caseVersion             Int? // latest CaseSnapshot version at assessment time

  // Condition (§4) — references existing Condition ids; classifications derived.
  supportingDiagnosisIds   Json? // string[] of Condition ids
  bodyRegion               String?
  laterality               String? // left | right | bilateral | n/a — CRE v1
  conditionSeverity        String? // mild | moderate | severe | end-stage | undetermined — CRE v1
  conditionChronicity      String? // acute | subacute | chronic | undetermined — CRE v1
  currentClinicalStatus    String? // under active treatment | surveillance | resolved | undetermined — CRE v1
  responsibleSpecialty     String?
  conditionTrajectory      String? // improving | stable | worsening | fluctuating | uncertain
  causalRelationshipStatus String? // from Condition.relatedness

  clinicalPurpose String?

  // CRE v1 — itemized, epistemically classified evidence: typed array of
  // { category, text, source, page, date, provider, objective, epistemic }
  // where epistemic ∈ documented_fact | patient_report | provider_opinion |
  // planner_inference | ai_inference | unknown. Deep normalization stays in
  // EvidenceLink; this is the assessment's classified view of it.
  evidenceItems Json?

  // Evidence assembly summaries (§5) — each underlying fact traces to a source
  // through the existing evidence buckets; these are the synthesized summaries.
  objectiveEvidenceSummary     String?
  subjectiveEvidenceSummary    String?
  functionalBasisSummary       String?
  priorTreatmentSummary        String?
  treatmentResponseSummary     String?
  treatingRecordSupportSummary String?

  medicalNecessityRationale String? // §6
  noTreatmentRisk           String?
  leastIntensiveRationale   String? // CRE v1 — why preferable to no/lower-intensity care
  timingRationale           String? // CRE v1 — when the care begins and why
  probabilityClassification ProbabilityClassification @default(INSUFFICIENTLY_SUPPORTED) // §7

  clinicalPathwayStage String? // §8
  clinicalPathway      String? // Phase B — conservative | surveillance | interventional | definitive surgical | revision | supportive
  frequencyRationale   String? // §10
  frequencySupported   Boolean @default(false)
  durationClass        String? // §11
  durationRationale    String?

  // Phase B — cross-recommendation coherence and alternatives.
  conflictFlags          Json? // {type, otherService, note}[]
  alternativesConsidered Json? // {alternative, rationale}[]
  inclusionRationale     String?

  weakeningEvidence       Json? // §13
  unknowns                Json? // §14
  missingEvidenceRequests Json?

  // Reasoning Reliability sprint — the full explainability payload:
  reasoningChain          Json? // ordered nodes complaint→…→approval, each with source, basis (fact/inference/assumption) and per-edge rationale
  evidenceSufficiency     Json? // per-dimension scores + threshold verdict + exactly what evidence is missing
  selfCritique            Json? // why recommended / why possibly wrong / assumptions / inferred-vs-documented
  confidenceVector        Json? // 10 independent confidence dimensions — never collapsed to one number
  alternativeExplanations Json? // competing diagnoses / alternative explanations from the case's own causation map

  supportingGuidelineAssessments  Json? // §15 — thin refs to existing guidelines
  supportingLiteratureAssessments Json? // §15 — thin refs to existing citations (ACCEPTED after the relevance re-filter)
  rejectedLiterature              Json? // CRE v1 — citations excluded at assessment time: { title, pmid?, reason }[]
  literatureSynthesis             String? // Phase C — one-paragraph synthesis of the body of literature
  residualUncertainty             String? // Phase C — plain-language summary of what remains unknown

  evidenceStrength         EvidenceStrength         @default(INSUFFICIENT) // §16
  recommendationConfidence RecommendationConfidence @default(INDETERMINATE)
  confidenceExplanation    String?

  costEligibilityStatus  String? // §17
  inclusionInTotalsStatus String? // included | excluded | contingency
  physicianReviewStatus  String?
  validationStatus       String?

  // Material-change fingerprint (§18): a change here invalidates prior approval.
  materialHash    String?
  generatedByModel String?
  supersededById  String? // the assessment that replaced this one (lineage; prior rows are preserved)
  reviewerMetadata Json? // CRE v1 — { invalidatedApproval?: bool, changedFields?: string[], priorPhysicianStatus?: string }
  errorDetail      String? // CRE v1 — populated when status = ERROR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([firmId])
  @@index([caseId, recommendationId])
}

model AttentionItem {
  id     String @id @default(uuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id], onDelete: Cascade)
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  caseVersionId String? // report/snapshot version the item was raised against

  category     String // e.g. diagnosis_mismatch, recommendation_conflict, physician_review_pending
  severity     AttentionSeverity
  title        String
  summary      String
  whyItMatters String
  suggestedAction String

  // What the item concerns, for a direct link + source traceability.
  entityType       String? // recommendation | condition | cost | document | report
  entityId         String?
  sourceDocumentId String?
  sourcePage       Int?

  // Stable fingerprint of the underlying finding — the dedup/supersede key so a
  // re-projection updates the same item instead of creating a duplicate.
  validationRuleId String
  exportBlocking   Boolean @default(false)

  status         AttentionStatus @default(OPEN)
  assignedUserId String?
  createdById    String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resolvedAt     DateTime?
  resolutionNote String?

  @@index([caseId])
  @@index([firmId])
  @@index([caseId, status])
  @@index([caseId, validationRuleId])
}

// ── EPIC-011: clinical interviews & reviewer credentials ─────────────────────

enum ProviderStatus {
  SUGGESTED // extracted from the records, not yet acted on
  CONFIRMED // user-confirmed part of the treating team
  DISMISSED // user judged incidental/not treating
}

// A provider affiliated with the case's care. Seeded as SUGGESTED from the
// parsed records (Document authors/providers, chronology providers) and then
// curated by the user. CONFIRMED providers and any provider carrying interview
// findings are PRESERVED across plan regeneration (never auto-deleted).
model TreatingProvider {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  name              String
  credentials       String?
  specialty         String?
  facility          String?
  contact           String?
  isTreating        Boolean        @default(true)
  status            ProviderStatus @default(SUGGESTED)
  // Normalized name key for regeneration reconciliation & dedupe.
  nameKey           String
  sourceDocumentIds Json? // [{ documentId, filename, pages }] the provider appears in
  addedById         String?

  createdAt DateTime @default(now())

  interviewFindings InterviewFinding[]

  @@index([caseId])
  @@index([firmId])
  @@index([caseId, nameKey])
}

enum InterviewSubject {
  PATIENT
  PROVIDER
}

// A single interview finding — categorized or free-text — from the patient or a
// treating provider. User-authored: NEVER wiped by regeneration, never
// fabricated. May link to a diagnosis / recommendation so it feeds that item.
model InterviewFinding {
  id     String @id @default(uuid())
  caseId String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  firmId String

  subject    InterviewSubject
  providerId String? // TreatingProvider, when subject = PROVIDER
  provider   TreatingProvider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  category String? // clinical taxonomy label, or null for free-text
  text     String
  quote    String? // verbatim patient/provider words

  interviewDate    DateTime?
  interviewedById  String? // the user who conducted the interview
  conditionId      String? // optional link → feeds that diagnosis
  futureCareItemId String? // optional link → feeds that recommendation

  createdById String?
  createdAt   DateTime @default(now())

  @@index([caseId])
  @@index([firmId])
  @@index([caseId, subject])
}

enum CredentialType {
  BOARD_CERTIFICATION
  CV
  LICENSE
  OTHER
}

// A credential document uploaded for a firm seat (board certification, CV,
// license). Firm-scoped; streamed through an authenticated route; GC'd on
// delete. Referenced in the report's Qualifications when the seat is on a case.
model UserCredential {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firmId String

  type       CredentialType
  label      String? // e.g. "ABPMR — Brain Injury Medicine"
  filename   String
  storageKey String

  createdById String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([firmId])
}
