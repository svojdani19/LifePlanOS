# ── Database (required) ──────────────────────────────────────────────────────
# LifePlanOS runs on its OWN dedicated database (not a shared schema). Pooled
# connection for the app; unpooled DIRECT_URL for migrations/DDL.
#
# Fully self-hosted (recommended for local/dev): `docker compose up -d`, then:
#   DATABASE_URL="postgresql://lifeplanos:lifeplanos@localhost:5432/lifeplanos?sslmode=disable"
#   DIRECT_URL="postgresql://lifeplanos:lifeplanos@localhost:5432/lifeplanos?sslmode=disable"
#
# Managed (e.g. Neon) — point at a dedicated database, not a shared one:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/lifeplanos?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/lifeplanos?sslmode=require"

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3100"        # used for Stripe redirect URLs
NODE_ENV="development"

# ── Auth / security (optional; sensible defaults) ────────────────────────────
SESSION_IDLE_MINUTES="30"              # idle timeout before a session is invalidated
LOGIN_MAX_FAILURES="10"                # failed logins per IP per 15 min before 429

# ── Object storage (optional — falls back to local ./uploads if unset) ───────
# Set these in production to store PHI files encrypted in S3.
S3_BUCKET=""
S3_PREFIX=""                           # optional key namespace, e.g. "prod/"
S3_KMS_KEY_ID=""                       # set for SSE-KMS; otherwise SSE-S3 (AES256)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── AI model provider (optional — deterministic mock is used when unset) ─────
# Anthropic is HIPAA-eligible under a BAA. Set both to activate a real model.
LLM_PROVIDER=""                        # "anthropic" | "openai" | unset (mock)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# ── Billing (optional — mock billing is used when unset) ─────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_SOLO=""
STRIPE_PRICE_SMALL_FIRM=""
STRIPE_PRICE_ENTERPRISE=""
