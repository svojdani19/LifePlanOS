{
  "name": "lifeplanos",
  "version": "0.1.0",
  "private": true,
  "description": "LifePlanOS — the operating system for life care planning. Standalone multi-tenant SaaS.",
  "scripts": {
    "dev": "next dev -p 3100",
    "dev:auto": "next dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "prisma migrate deploy && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@prisma/client": "^5.20.0",
    "clsx": "^2.1.1",
    "docx": "^9.7.1",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.8.0",
    "next": "14.2.5",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
